# Timezone
TZ=America/New_York

# Absolute path on host where files are stored
FILES_PATH=

# Public URL of the app (no trailing slash)
APP_URL=https://share.example.com

# Display name shown in the UI header and browser tab (defaults to 'static-oidc' if not set)
APP_NAME=My Files

# OIDC Provider (any compliant provider)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ADMIN_GROUP=static-oidc-admins

# Groups claim name — default is 'groups'
# For AWS Cognito set this to: cognito:groups
OIDC_GROUPS_CLAIM=groups

# Note: No VITE_* variables needed.
# The frontend fetches its config from the backend at runtime via /api/config.